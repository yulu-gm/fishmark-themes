{
  "id": "rain-glass",
  "contractVersion": 2,
  "name": "Rain Glass",
  "version": "2.0.0",
  "author": "FishMark",
  "supports": {
    "light": true,
    "dark": true
  },
  "tokens": {
    "light": "./tokens/light.css",
    "dark": "./tokens/dark.css"
  },
  "styles": {
    "ui": "./styles/ui.css",
    "editor": "./styles/editor.css",
    "markdown": "./styles/markdown.css",
    "titlebar": "./styles/titlebar.css"
  },
  "layout": {
    "titlebar": "./layout/titlebar.json"
  },
  "scene": {
    "id": "rain-scene",
    "sharedUniforms": {
      "rainAmount": 0.72,
      "glassBlur": 0.58
    }
  },
  "parameters": [
    {
      "id": "rainAmount",
      "label": "雨量",
      "description": "控制雨滴密度与玻璃上雨迹的总量。",
      "type": "slider",
      "min": 0,
      "max": 1,
      "step": 0.05,
      "default": 0.72,
      "uniform": "rainAmount"
    },
    {
      "id": "glassBlur",
      "label": "玻璃模糊",
      "description": "玻璃雾气感，越高背景越朦胧。",
      "type": "slider",
      "min": 0,
      "max": 1,
      "step": 0.05,
      "default": 0.58,
      "uniform": "glassBlur"
    },
    {
      "id": "workspaceGlassOpacity",
      "label": "Workspace Glass",
      "description": "Controls the opacity of the integrated workspace glass shell.",
      "type": "slider",
      "min": 0,
      "max": 1,
      "step": 0.05,
      "default": 0.24
    },
    {
      "id": "enableLightning",
      "label": "闪电效果",
      "description": "偶发的雷电闪光。关闭后画面更加平静。",
      "type": "toggle",
      "default": true,
      "uniform": "enableLightning"
    },
    {
      "id": "enableZoomWobble",
      "label": "镜头呼吸",
      "description": "微小的缓慢镜头缩放，模拟手持拍摄的呼吸感。",
      "type": "toggle",
      "default": true,
      "uniform": "enableZoomWobble"
    },
    {
      "id": "colorGradeStrength",
      "label": "冷色调强度",
      "description": "画面冷蓝调的周期性强度，0 表示保持原色。",
      "type": "slider",
      "min": 0,
      "max": 1,
      "step": 0.05,
      "default": 0.8,
      "uniform": "colorGradeStrength"
    }
  ],
  "surfaces": {
    "workbenchBackground": {
      "kind": "fragment",
      "scene": "rain-scene",
      "shader": "./shaders/workbench-background.glsl",
      "channels": {
        "0": {
          "type": "image",
          "src": "./assets/textures/rain-window-scene.png"
        }
      }
    },
    "titlebarBackdrop": {
      "kind": "fragment",
      "scene": "rain-scene",
      "shader": "./shaders/titlebar-backdrop.glsl",
      "channels": {
        "0": {
          "type": "image",
          "src": "./assets/textures/rain-window-scene.png"
        }
      }
    }
  }
}
